# cogbench/.env — copy to `.env` and fill in.
# ── HuggingFace ────────────────────────────────────────────────
# Needed to download gated checkpoints (Llama, Gemma).
# Generate at https://huggingface.co/settings/tokens (read scope is enough).
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Judge panel ───────────────────────────────────────────────
# OpenAI-compatible endpoint serving the judge LLMs.
# Local Ollama: http://localhost:11434/v1
# Local vLLM:   http://localhost:8000/v1
JUDGE_BASE_URL=http://localhost:11434/v1
JUDGE_MODEL=qwen2.5:14b

# ── vLLM (optional) ───────────────────────────────────────────
# Set to 1 to force the HuggingFace generation path even if vLLM is importable.
COGBENCH_NO_VLLM=0

# ── Grader tuning ─────────────────────────────────────────────
COGBENCH_GRADER_CHUNK=5000
COGBENCH_JUDGE_BATCH=8

# ── Weights & Biases (optional) ───────────────────────────────
WANDB_API_KEY=
WANDB_PROJECT=cogbench-eval
WANDB_MODE=online                      # "offline" to disable uploads
