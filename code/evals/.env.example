# evals/.env — copy to `.env` and fill in.
# HuggingFace: public bench datasets (BigBench, BigToM, FinQA, etc.)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Trust-remote-code for a handful of bench datasets
HF_DATASETS_TRUST_REMOTE_CODE=1

# Weights & Biases (optional)
WANDB_API_KEY=
WANDB_PROJECT=cogbench-evals
WANDB_MODE=online                      # "offline" to disable uploads
