# generation/.env — copy this to `.env` and edit.
# OpenAI-compatible endpoint for the generator LLM
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
GENERATOR_MODEL=deepseek-r1:32b

# Judge panel
COGBENCH_JUDGE_MODELS=qwen2.5:14b,mistral-nemo:12b
COGBENCH_JUDGE_CONSENSUS=unanimous
COGBENCH_JUDGE_ENDPOINT=http://localhost:11434/v1

# Generation tuning
GEN_WORKERS=8
GEN_MAX_TOKENS=4096
GEN_TEMPERATURE=0.7
